{
  "manifest_version": 3,
  "name": "xdAnswers",
  "version": "5.3.0",
  "description": "AI-powered answers for educational tests.",
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "xd-trigger-answer": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "xdAnswers: trigger answer for current question"
    }
  },
  "action": {
    "default_title": "xdAnswers Settings",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://naurok.com.ua/test/testing/*",
        "*://naurok.ua/test/testing/*",
        "*://naurok.com.ua/test/realtime-client/*",
        "*://naurok.ua/test/realtime-client/*"
      ],
      "js": [
        "version.js",
        "src/core/constants.js",
        "src/core/settings-defaults.js",
        "src/core/state.js",
        "src/core/version.js",
        "src/core/settings.js",
        "src/core/http.js",
        "src/core/markdown.js",
        "src/ai/search.js",
        "src/ai/request.js",
        "src/ai/stream.js",
        "src/ai/parse.js",
        "src/ai/answer.js",
        "src/ai/stream-answer.js",
        "src/dom/match.js",
        "src/dom/select.js",
        "src/dom/silent.js",
        "src/dom/oneclick.js",
        "src/ai/process.js",
        "src/ui/draggable.js",
        "src/ui/styles.js",
        "src/ui/helper.js",
        "providers/naurok.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "*://vseosvita.ua/test/go-olp*",
        "*://vseosvita.ua/test/start/*"
      ],
      "js": [
        "version.js",
        "src/core/constants.js",
        "src/core/settings-defaults.js",
        "src/core/state.js",
        "src/core/version.js",
        "src/core/settings.js",
        "src/core/http.js",
        "src/core/markdown.js",
        "src/ai/search.js",
        "src/ai/request.js",
        "src/ai/stream.js",
        "src/ai/parse.js",
        "src/ai/answer.js",
        "src/ai/stream-answer.js",
        "src/dom/match.js",
        "src/dom/select.js",
        "src/dom/silent.js",
        "src/dom/oneclick.js",
        "src/ai/process.js",
        "src/ui/draggable.js",
        "src/ui/styles.js",
        "src/ui/helper.js",
        "providers/vseosvita.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "*://docs.google.com/forms/u/*/d/e/*/viewform*",
        "*://docs.google.com/forms/u/*/d/e/*/formResponse*",
        "*://docs.google.com/forms/d/e/*/viewform*",
        "*://docs.google.com/forms/d/e/*/formResponse*"
      ],
      "js": [
        "version.js",
        "src/core/constants.js",
        "src/core/settings-defaults.js",
        "src/core/state.js",
        "src/core/version.js",
        "src/core/settings.js",
        "src/core/http.js",
        "src/core/markdown.js",
        "src/ai/search.js",
        "src/ai/request.js",
        "src/ai/stream.js",
        "src/ai/parse.js",
        "src/ai/answer.js",
        "src/ai/stream-answer.js",
        "src/dom/match.js",
        "src/dom/select.js",
        "src/dom/silent.js",
        "src/dom/oneclick.js",
        "src/ai/process.js",
        "src/ui/draggable.js",
        "src/ui/styles.js",
        "src/ui/helper.js",
        "providers/gforms.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "*://justclass.com.ua/hw/*"
      ],
      "js": [
        "version.js",
        "src/core/constants.js",
        "src/core/settings-defaults.js",
        "src/core/state.js",
        "src/core/version.js",
        "src/core/settings.js",
        "src/core/http.js",
        "src/core/markdown.js",
        "src/ai/search.js",
        "src/ai/request.js",
        "src/ai/stream.js",
        "src/ai/parse.js",
        "src/ai/answer.js",
        "src/ai/stream-answer.js",
        "src/dom/match.js",
        "src/dom/select.js",
        "src/dom/silent.js",
        "src/dom/oneclick.js",
        "src/ai/process.js",
        "src/ui/draggable.js",
        "src/ui/styles.js",
        "src/ui/helper.js",
        "providers/justclass.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": [
        "*://forms.office.com/Pages/ResponsePage.aspx*",
        "*://forms.office.com/pages/responsepage.aspx*",
        "*://forms.office.com/r/*"
      ],
      "js": [
        "version.js",
        "src/core/constants.js",
        "src/core/settings-defaults.js",
        "src/core/state.js",
        "src/core/version.js",
        "src/core/settings.js",
        "src/core/http.js",
        "src/core/markdown.js",
        "src/ai/search.js",
        "src/ai/request.js",
        "src/ai/stream.js",
        "src/ai/parse.js",
        "src/ai/answer.js",
        "src/ai/stream-answer.js",
        "src/dom/match.js",
        "src/dom/select.js",
        "src/dom/silent.js",
        "src/dom/oneclick.js",
        "src/ai/process.js",
        "src/ui/draggable.js",
        "src/ui/styles.js",
        "src/ui/helper.js",
        "providers/msforms.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
